# ═══════════════════════════════════════════════════════════════════════════════
# DEVLEDGER ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ─────────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# For local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/devledger

# For MongoDB Atlas (recommended):
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/devledger?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://gunjit15_db_user:<db_password>@devledger.wy5drcx.mongodb.net/

# ─────────────────────────────────────────────────────────────────────────────
# JWT CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=your_super_secure_jwt_secret_key_here_minimum_32_chars

# Token expiry times
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─────────────────────────────────────────────────────────────────────────────
# CORS CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
