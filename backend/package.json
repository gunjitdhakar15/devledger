        "deep-diff": "^1.0.2",
        "fastify-plugin": "^5.0.1"
    },
    "devDependencies": {
        "@types/node": "^22.15.32",
        "@types/bcrypt": "^5.0.2",
        "@types/deep-diff": "^1.0.5",
        "typescript": "^5.8.3",
        "tsx": "^4.20.3",
        "vitest": "^3.2.4",
        "@typescript-eslint/eslint-plugin": "^8.35.1",
        "@typescript-eslint/parser": "^8.35.1",
