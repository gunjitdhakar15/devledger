{
    "name": "devledger-backend",
    "version": "1.0.0",
    "description": "High-Performance Project Management Dashboard - Production-Grade Backend",
    "main": "dist/server.js",
    "type": "module",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "node -e \"console.log('DevLedger backend runs directly with tsx in production builds.')\"",
        "start": "tsx src/bootstrap.ts",
        "lint": "eslint src --ext .ts",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "db:seed": "tsx src/scripts/seed.ts",
        "db:seed:clean": "tsx src/scripts/seed.ts --clean",
        "db:status": "tsx src/scripts/db-utils.ts status",
        "db:reset": "tsx src/scripts/db-utils.ts reset"
    },
    "dependencies": {
        "fastify": "^5.3.3",
        "@fastify/jwt": "^9.1.0",
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^10.1.0",
        "@fastify/helmet": "^13.0.1",
        "@fastify/rate-limit": "^10.2.2",
        "fastify-type-provider-zod": "^4.0.0",
        "mongoose": "^8.15.2",
        "zod": "^3.25.51",
        "bcrypt": "^6.0.0",
        "fastify-plugin": "^5.0.1",
        "tsx": "^4.20.3"
    },
    "devDependencies": {
        "@types/node": "^22.15.32",
        "@types/bcrypt": "^5.0.2",
        "typescript": "^5.8.3",
        "vitest": "^3.2.4",
        "@typescript-eslint/eslint-plugin": "^8.35.1",
        "@typescript-eslint/parser": "^8.35.1",
        "eslint": "^9.29.0",
        "pino-pretty": "^13.1.1"
    },
    "engines": {
        "node": "22.x"
    }
}
